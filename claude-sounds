#!/bin/bash
set -euo pipefail

SOUNDS_DIR="${CLAUDE_SOUNDS_DIR:-$HOME/.claude/sounds}"
CONFIG="$SOUNDS_DIR/sounds-config.json"
STATE="$SOUNDS_DIR/state.json"
DEFAULT_CONFIG="$SOUNDS_DIR/sounds-config.default.json"
DISPATCHER="$SOUNDS_DIR/dispatcher.sh"
PACKS_DIR="$SOUNDS_DIR/packs"

VALID_CATEGORIES=("completion" "attention" "lifecycle" "progress" "input" "context")

ensure_state() {
  if [ ! -f "$STATE" ]; then
    echo '{"global_mute":false,"muted_categories":{}}' > "$STATE"
  fi
}

cmd_on() {
  ensure_state
  jq '.global_mute = false' "$STATE" > "$STATE.tmp" && mv "$STATE.tmp" "$STATE"
  echo "Claude Code Sounds: ON"
}

cmd_off() {
  ensure_state
  jq '.global_mute = true' "$STATE" > "$STATE.tmp" && mv "$STATE.tmp" "$STATE"
  echo "Claude Code Sounds: OFF"
}

cmd_status() {
  ensure_state
  local global_mute
  global_mute=$(jq -r '.global_mute // false' "$STATE")

  if [ "$global_mute" = "true" ]; then
    echo "Claude Code Sounds: OFF"
  else
    echo "Claude Code Sounds: ON"
  fi

  for cat in "${VALID_CATEGORIES[@]}"; do
    local cat_enabled cat_muted status event_count
    cat_enabled=$(jq -r ".categories.\"$cat\".enabled // true" "$CONFIG" 2>/dev/null || echo "true")
    cat_muted=$(jq -r ".muted_categories.\"$cat\" // false" "$STATE")
    event_count=$(jq -r "[.events[] | select(.category == \"$cat\")] | length" "$CONFIG" 2>/dev/null || echo "0")

    if [ "$cat_enabled" != "true" ] || [ "$cat_muted" = "true" ]; then
      status="off"
    else
      status="on"
    fi

    printf "  %-14s %-4s (%s events)\n" "$cat" "$status" "$event_count"
  done
}

is_valid_category() {
  local cat="$1"
  for valid in "${VALID_CATEGORIES[@]}"; do
    if [ "$cat" = "$valid" ]; then return 0; fi
  done
  return 1
}

cmd_mute() {
  local cat="${1:-}"
  if [ -z "$cat" ]; then
    echo "Usage: claude-sounds mute <category>"
    echo "Categories: ${VALID_CATEGORIES[*]}"
    exit 1
  fi
  if ! is_valid_category "$cat"; then
    echo "Unknown category: $cat"
    echo "Valid categories: ${VALID_CATEGORIES[*]}"
    exit 1
  fi
  ensure_state
  jq ".muted_categories.\"$cat\" = true" "$STATE" > "$STATE.tmp" && mv "$STATE.tmp" "$STATE"
  echo "Muted: $cat"
}

cmd_unmute() {
  local cat="${1:-}"
  if [ -z "$cat" ]; then
    echo "Usage: claude-sounds unmute <category>"
    echo "Categories: ${VALID_CATEGORIES[*]}"
    exit 1
  fi
  if ! is_valid_category "$cat"; then
    echo "Unknown category: $cat"
    echo "Valid categories: ${VALID_CATEGORIES[*]}"
    exit 1
  fi
  ensure_state
  jq "del(.muted_categories.\"$cat\")" "$STATE" > "$STATE.tmp" && mv "$STATE.tmp" "$STATE"
  echo "Unmuted: $cat"
}

cmd_test_event() {
  local event="${1:-}"
  if [ "$event" = "--all" ]; then
    local events
    events=$(jq -r '.events | to_entries[] | select(.value.enabled == true) | .key' "$CONFIG")
    for ev in $events; do
      echo "Testing: $ev"
      echo "{\"hook_event_name\": \"$ev\"}" | bash "$DISPATCHER"
      sleep 1
    done
    return
  fi
  if [ -z "$event" ]; then
    echo "Usage: claude-sounds test <event|--all>"
    exit 1
  fi
  local event_cfg
  event_cfg=$(jq -r ".events.\"$event\" // empty" "$CONFIG")
  if [ -z "$event_cfg" ] || [ "$event_cfg" = "null" ]; then
    echo "Unknown event: $event"
    echo "Run 'claude-sounds list' to see available events."
    exit 1
  fi
  rm -f "$SOUNDS_DIR/debounce/$event"
  echo "{\"hook_event_name\": \"$event\"}" | bash "$DISPATCHER"
}

cmd_list() {
  local filter_cat="${1:-}"
  if [ "$filter_cat" = "--category" ]; then
    filter_cat="${2:-}"
    if [ -z "$filter_cat" ]; then
      echo "Usage: claude-sounds list --category <category>"
      exit 1
    fi
  else
    filter_cat=""
  fi

  printf "%-22s %-12s %-6s %-8s %s\n" "EVENT" "CATEGORY" "TYPE" "ENABLED" "SOUND/MESSAGE"
  printf "%-22s %-12s %-6s %-8s %s\n" "-----" "--------" "----" "-------" "-------------"

  local events_json
  if [ -n "$filter_cat" ]; then
    events_json=$(jq -r ".events | to_entries[] | select(.value.category == \"$filter_cat\")" "$CONFIG")
  else
    events_json=$(jq -r '.events | to_entries[]' "$CONFIG")
  fi

  echo "$events_json" | jq -r '
    [.key,
     (.value.category // "-"),
     (.value.type // "-"),
     (if .value.enabled then "on" else "off" end),
     (if .value.type == "tts" then .value.message // "-"
      elif .value.type == "audio" then .value.sound // "-"
      else "-" end)
    ] | @tsv' | while IFS=$'\t' read -r name cat type enabled sound; do
    printf "%-22s %-12s %-6s %-8s %s\n" "$name" "$cat" "$type" "$enabled" "$sound"
  done
}

cmd_config() {
  "${EDITOR:-vi}" "$CONFIG"
}

cmd_reset() {
  if [ ! -f "$DEFAULT_CONFIG" ]; then
    echo "Default config not found at $DEFAULT_CONFIG"
    exit 1
  fi
  if [ -f "$CONFIG" ]; then
    cp "$CONFIG" "$CONFIG.bak"
    echo "Backed up current config to $CONFIG.bak"
  fi
  cp "$DEFAULT_CONFIG" "$CONFIG"
  echo "Config reset to defaults."
}

cmd_pack_list() {
  if [ ! -d "$PACKS_DIR" ] || [ -z "$(ls -A "$PACKS_DIR" 2>/dev/null)" ]; then
    echo "No packs available."
    return
  fi
  echo "Available packs:"
  for pack_dir in "$PACKS_DIR"/*/; do
    [ -d "$pack_dir" ] || continue
    local pack_json="$pack_dir/pack.json"
    [ -f "$pack_json" ] || continue
    local name desc version
    name=$(jq -r '.name' "$pack_json")
    desc=$(jq -r '.description' "$pack_json")
    version=$(jq -r '.version' "$pack_json")
    printf "  %-12s %s (v%s)\n" "$name" "$desc" "$version"
  done
}

cmd_pack_install() {
  local pack_name="${1:-}"
  if [ -z "$pack_name" ]; then
    echo "Usage: claude-sounds pack install <name|default>"
    exit 1
  fi

  ensure_state

  if [ "$pack_name" = "default" ]; then
    cmd_pack_install_default
    return
  fi

  local pack_dir="$PACKS_DIR/$pack_name"
  local pack_json="$pack_dir/pack.json"

  if [ ! -d "$pack_dir" ]; then
    echo "Error: pack '$pack_name' not found. Run 'claude-sounds pack list' to see available packs."
    exit 1
  fi
  if [ ! -f "$pack_json" ]; then
    echo "Error: pack '$pack_name' is invalid: missing pack.json"
    exit 1
  fi

  # Validate all referenced audio files exist
  local missing_files=()
  while IFS= read -r sound_file; do
    if [ ! -f "$pack_dir/audio/$sound_file" ]; then
      missing_files+=("$sound_file")
    fi
  done < <(jq -r '.events[].sound // empty' "$pack_json")

  if [ ${#missing_files[@]} -gt 0 ]; then
    echo "Error: pack '$pack_name' is invalid: missing audio file '${missing_files[0]}' referenced in pack.json"
    exit 1
  fi

  # Save current config
  local current_pack
  current_pack=$(jq -r '.active_pack // empty' "$STATE")
  if [ -n "$current_pack" ]; then
    cp "$CONFIG" "$SOUNDS_DIR/sounds-config.$current_pack.json"
  else
    cp "$CONFIG" "$SOUNDS_DIR/sounds-config.custom.json"
  fi

  # Check for previously saved config for this pack
  local saved_config="$SOUNDS_DIR/sounds-config.$pack_name.json"
  if [ -f "$saved_config" ]; then
    cp "$saved_config" "$CONFIG"
  else
    # Generate config from pack manifest + defaults
    local new_config
    new_config=$(jq --arg pack "$pack_name" --slurpfile pd "$pack_json" '
      # Use pack categories if present, otherwise keep defaults
      (if $pd[0].categories then $pd[0].categories else .categories end) as $cats |
      # Rewrite pack event sound paths
      ($pd[0].events | to_entries | map(.value.sound = "audio/\($pack)/\(.value.sound)") | from_entries) as $pack_events |
      {
        version: .version,
        defaults: .defaults,
        categories: $cats,
        events: (.events + $pack_events)
      }
    ' "$DEFAULT_CONFIG")
    echo "$new_config" > "$CONFIG"
  fi

  # Copy audio files
  mkdir -p "$SOUNDS_DIR/audio/$pack_name"
  cp "$pack_dir/audio/"* "$SOUNDS_DIR/audio/$pack_name/" 2>/dev/null || true

  # Update state
  jq --arg p "$pack_name" '.active_pack = $p' "$STATE" > "$STATE.tmp" && mv "$STATE.tmp" "$STATE"

  local sound_count
  sound_count=$(find "$pack_dir/audio/" -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')
  echo "Installed pack '$pack_name' ($sound_count sounds). Previous config saved."
}

cmd_pack_install_default() {
  if [ ! -f "$DEFAULT_CONFIG" ]; then
    echo "Default config not found at $DEFAULT_CONFIG"
    exit 1
  fi

  ensure_state

  # Save current config under active pack name
  local current_pack
  current_pack=$(jq -r '.active_pack // empty' "$STATE")
  if [ -n "$current_pack" ] && [ -f "$CONFIG" ]; then
    cp "$CONFIG" "$SOUNDS_DIR/sounds-config.$current_pack.json"
  fi

  cp "$DEFAULT_CONFIG" "$CONFIG"
  jq 'del(.active_pack)' "$STATE" > "$STATE.tmp" && mv "$STATE.tmp" "$STATE"

  local saved_as=""
  if [ -n "$current_pack" ]; then
    saved_as=" Previous config saved as $current_pack."
  fi
  echo "Restored default config.$saved_as"
}

cmd_pack_active() {
  ensure_state
  local active
  active=$(jq -r '.active_pack // empty' "$STATE")
  if [ -z "$active" ]; then
    echo "No pack active (using default config)"
    return
  fi
  local pack_json="$PACKS_DIR/$active/pack.json"
  if [ -f "$pack_json" ]; then
    local version
    version=$(jq -r '.version' "$pack_json")
    echo "Active pack: $active (v$version)"
  else
    echo "Active pack: $active"
  fi
}

cmd_pack() {
  local subcmd="${1:-}"
  case "$subcmd" in
    list) cmd_pack_list ;;
    install) cmd_pack_install "${2:-}" ;;
    active) cmd_pack_active ;;
    *)
      echo "Usage: claude-sounds pack <list|install|active>"
      echo ""
      echo "Commands:"
      echo "  list                  List available sound packs"
      echo "  install <name>        Install a sound pack"
      echo "  install default       Restore default config"
      echo "  active                Show currently active pack"
      exit 1
      ;;
  esac
}

case "${1:-}" in
  on)     cmd_on ;;
  off)    cmd_off ;;
  status) cmd_status ;;
  mute)   cmd_mute "${2:-}" ;;
  unmute) cmd_unmute "${2:-}" ;;
  test)   cmd_test_event "${2:-}" ;;
  list)   cmd_list "${2:-}" "${3:-}" ;;
  config) cmd_config ;;
  reset)  cmd_reset ;;
  pack)   cmd_pack "${2:-}" "${3:-}" ;;
  *)
    echo "Usage: claude-sounds <command>"
    echo ""
    echo "Commands:"
    echo "  on                    Unmute all sounds"
    echo "  off                   Mute all sounds"
    echo "  status                Show current state"
    echo "  mute <category>       Mute a category"
    echo "  unmute <category>     Unmute a category"
    echo "  test <event>          Play sound for an event"
    echo "  test --all            Play all enabled sounds"
    echo "  list                  List all events"
    echo "  list --category <c>   List events in category"
    echo "  config                Open config in \$EDITOR"
    echo "  reset                 Reset config to defaults"
    echo "  pack <subcommand>     Manage sound packs"
    exit 1
    ;;
esac
